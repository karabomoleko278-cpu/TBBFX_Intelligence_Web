#!/bin/sh
set -eu

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

if command -v python >/dev/null 2>&1; then
  python scripts/security/secret_scan.py --staged
elif command -v py >/dev/null 2>&1; then
  py -3 scripts/security/secret_scan.py --staged
else
  echo "[SECURITY ALERT] Python is required for the TBBFX pre-commit secret gate." >&2
  exit 1
fi
