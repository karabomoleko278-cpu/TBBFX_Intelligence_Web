# TBBFX production reverse proxy template.
# Copy outside the repository, replace paths/hostnames, and validate with
# `nginx -t` before reloading. Application middleware remains the authoritative
# 60 requests/minute/IP guardrail; Nginx adds a second defensive layer.

worker_processes auto;
pid logs/nginx.pid;

events {
    worker_connections 2048;
}

http {
    include       mime.types;
    default_type  application/octet-stream;
    sendfile      on;
    keepalive_timeout 30;
    server_tokens off;

    log_format tbbfx '$remote_addr - $request_method $uri $status '
                     '$body_bytes_sent $request_time $upstream_response_time';
    access_log logs/tbbfx-access.log tbbfx;
    error_log  logs/tbbfx-error.log warn;

    limit_req_zone $binary_remote_addr zone=tbbfx_public:10m rate=1r/s;

    proxy_cache_path cache/tbbfx_macro
        levels=1:2
        keys_zone=tbbfx_macro:20m
        max_size=256m
        inactive=24h
        use_temp_path=off;

    map $http_upgrade $connection_upgrade {
        default upgrade;
        ''      close;
    }

    map "$http_authorization$http_x_tbbfx_key$arg_key" $private_request {
        default 1;
        ""      0;
    }

    upstream featurefactory_pool {
        least_conn;
        server 127.0.0.1:8000 max_fails=3 fail_timeout=15s;
        server 127.0.0.1:8001 max_fails=3 fail_timeout=15s;
        server 127.0.0.1:8002 max_fails=3 fail_timeout=15s;
        keepalive 32;
    }

    upstream signalr_store {
        server 127.0.0.1:5000 max_fails=3 fail_timeout=15s;
        keepalive 16;
    }

    server {
        listen 127.0.0.1:8080;
        server_name _;

        add_header X-Content-Type-Options nosniff always;
        add_header Referrer-Policy no-referrer always;
        add_header X-TBBFX-Gateway nginx always;

        location = /healthz {
            access_log off;
            default_type application/json;
            return 200 '{"status":"ok","gateway":"tbbfx-nginx"}';
        }

        # Twelve-hour analytical datasets. Never cache authenticated/keyed calls.
        location ~ ^/api/macro/(liquidity-index|cot-positioning|yield-curve)$ {
            limit_req zone=tbbfx_public burst=20 nodelay;
            proxy_pass http://featurefactory_pool;
            proxy_http_version 1.1;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_cache tbbfx_macro;
            proxy_cache_key "$scheme$request_method$host$uri$is_args$args";
            proxy_cache_valid 200 12h;
            proxy_cache_bypass $private_request;
            proxy_no_cache $private_request $upstream_http_set_cookie;
            add_header X-TBBFX-Cache $upstream_cache_status always;
        }

        # Five-minute macro datasets: current enough for dashboards, cheap for origins.
        location ~ ^/api/macro/(yield-spreads|sentiment|calendar|geopolitical-feed|geospatial-nodes)$ {
            limit_req zone=tbbfx_public burst=20 nodelay;
            proxy_pass http://featurefactory_pool;
            proxy_http_version 1.1;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_cache tbbfx_macro;
            proxy_cache_valid 200 5m;
            proxy_cache_bypass $private_request;
            proxy_no_cache $private_request $upstream_http_set_cookie;
            add_header X-TBBFX-Cache $upstream_cache_status always;
        }

        # FeatureFactory analytical routes. Live/order-flow traffic is never cached.
        location /api/ {
            limit_req zone=tbbfx_public burst=20 nodelay;
            proxy_pass http://featurefactory_pool;
            proxy_http_version 1.1;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_hide_header Cache-Control;
            add_header Cache-Control "private, no-store" always;
            add_header CDN-Cache-Control "no-store" always;
        }

        # SignalR, feature cache, and public order-flow reads stay on one stateful node.
        location ~ ^/(features|hub|api/orderflow|api/market) {
            limit_req zone=tbbfx_public burst=20 nodelay;
            proxy_pass http://signalr_store;
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection $connection_upgrade;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_buffering off;
            proxy_read_timeout 120s;
            proxy_hide_header Cache-Control;
            add_header Cache-Control "private, no-store" always;
            add_header CDN-Cache-Control "no-store" always;
        }

        location / {
            proxy_pass http://featurefactory_pool;
            proxy_http_version 1.1;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            add_header Cache-Control "private, no-store" always;
        }
    }
}
